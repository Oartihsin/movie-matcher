{
  "expo": {
    "name": "Movie Matcher",
    "slug": "movie-matcher",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "moviematcher",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1c1917"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.moviematcher.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Movie Matcher needs camera access for your profile photo.",
        "NSPhotoLibraryUsageDescription": "Movie Matcher needs photo library access for your profile photo.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.moviematcher.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1c1917",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c6feab19-7243-4b3c-9dda-7eaf3cf88c6c"
      }
    },
    "owner": "oartihsins-organization"
  }
}
