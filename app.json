{
  "expo": {
    "name": "Movie Matcher",
    "slug": "movie-matcher",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "moviematcher",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#16213e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.moviematcher.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Movie Matcher needs camera access for your profile photo.",
        "NSPhotoLibraryUsageDescription": "Movie Matcher needs photo library access for your profile photo."
      }
    },
    "android": {
      "package": "com.moviematcher.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#16213e",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
